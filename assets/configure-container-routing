#!/bin/bash
# configure-container-routing - Configure routing for a single container app
#
# This script is called by container services in their ExecStartPre to
# generate Traefik routing configuration before the container starts.
#
# Usage: configure-container-routing <app_id>
#
# Port-based routing: each app gets a dedicated HTTPS port from the 4430-4450
# range, assigned on first start and persisted in /etc/halos/port-registry.
# A path redirect on port 443 provides discoverability (e.g., /signalk-server/ → :4430).
#
# This script reads /etc/halos/routing.d/<app_id>.yml and generates:
# 1. Docker-compose override file in /run/halos/routing-labels/
# 2. Per-app ForwardAuth middleware in /etc/halos/traefik-dynamic.d/ (if needed)
# 3. Path redirect config in /etc/halos/traefik-dynamic.d/
# 4. HALOS_EXTERNAL_PORT in the app's runtime env directory
#
# Provided by halos-core-containers. Other proxy packages (caddy, nginx)
# would provide their own implementation of this command.

set -e

# Directories can be overridden via environment variables for testing
ROUTING_DIR="${ROUTING_DIR:-/etc/halos/routing.d}"
OUTPUT_DIR="${OUTPUT_DIR:-/run/halos/routing-labels}"
MIDDLEWARE_DIR="${MIDDLEWARE_DIR:-/etc/halos/traefik-dynamic.d}"
PORT_REGISTRY="${PORT_REGISTRY:-/etc/halos/port-registry}"
PORT_RANGE_START=4430
PORT_RANGE_END=4450

# Get HALOS_DOMAIN from environment or derive from hostname
if [ -z "${HALOS_DOMAIN}" ]; then
    HOSTNAME="$(hostname -s)"
    HALOS_DOMAIN="${HOSTNAME}.local"
fi

log() {
    echo "[configure-container-routing] $1"
}

# Parse YAML value - simple grep-based parser for our known format
yaml_get() {
    local key="$1"
    grep "^${key}:" | sed "s/^${key}:[[:space:]]*//" | sed 's/^"//' | sed 's/"$//'
}

# Parse nested YAML value
yaml_get_nested() {
    local parent="$1"
    local child="$2"
    sed -n "/^${parent}:/,/^[a-z]/p" | grep "^  ${child}:" | sed "s/^  ${child}:[[:space:]]*//" | sed "s/^[\"']//; s/[\"']$//"
}

# Parse deeply nested YAML value (3 levels)
yaml_get_deep() {
    local parent="$1"
    local child="$2"
    local grandchild="$3"
    sed -n "/^${parent}:/,/^[a-z]/p" | sed -n "/^  ${child}:/,/^  [a-z]/p" | grep "^    ${grandchild}:" | sed "s/^    ${grandchild}:[[:space:]]*//" | sed 's/^"//' | sed 's/"$//'
}

# --- Port Registry ---

# Get or assign a port for an app from the persistent registry.
# Returns the port number. Creates the registry file if needed.
get_or_assign_port() {
    local app_id="$1"

    # Ensure registry directory exists
    mkdir -p "$(dirname "${PORT_REGISTRY}")"

    # Create registry file if it doesn't exist
    [ -f "${PORT_REGISTRY}" ] || touch "${PORT_REGISTRY}"

    # Check if app already has a port
    local existing_port
    existing_port=$(grep "^${app_id}=" "${PORT_REGISTRY}" 2>/dev/null | cut -d= -f2)
    if [ -n "${existing_port}" ]; then
        echo "${existing_port}"
        return 0
    fi

    # Find next available port
    local port
    for port in $(seq ${PORT_RANGE_START} ${PORT_RANGE_END}); do
        if ! grep -q "=${port}$" "${PORT_REGISTRY}" 2>/dev/null; then
            echo "${app_id}=${port}" >> "${PORT_REGISTRY}"
            log "Assigned port ${port} to ${app_id}"
            echo "${port}"
            return 0
        fi
    done

    log "ERROR: No available ports in range ${PORT_RANGE_START}-${PORT_RANGE_END}"
    return 1
}

# Check if a routing file has custom forward auth headers
has_custom_headers() {
    local file="$1"
    grep -q "forward_auth:" "$file" 2>/dev/null && \
        grep -q "headers:" "$file" 2>/dev/null && \
        grep -qE "^[[:space:]]{6,}[A-Za-z]" "$file" 2>/dev/null
}

# Extract custom headers as key=value pairs
get_custom_headers() {
    local file="$1"
    sed -n '/^auth:/,/^[a-z]/p' "$file" | \
        sed -n '/forward_auth:/,/^  [a-z]/p' | \
        sed -n '/headers:/,/^    [a-z]/p' | \
        grep -E "^[[:space:]]{6,}[A-Za-z]" | \
        sed 's/^[[:space:]]*//' | \
        sed 's/:[[:space:]]*/=/'
}

# Generate per-app ForwardAuth middleware YAML
generate_middleware() {
    local app_id="$1"
    local routing_file="$2"
    local middleware_file="${MIDDLEWARE_DIR}/authelia-${app_id}.yml"

    log "Generating middleware for ${app_id}"

    local headers=""
    while IFS='=' read -r authelia_header app_header; do
        if [ -n "${authelia_header}" ]; then
            headers="${headers}
          - ${authelia_header}"
        fi
    done < <(get_custom_headers "$routing_file")

    cat > "${middleware_file}" << EOF
# Per-app ForwardAuth middleware for ${app_id}
# Auto-generated by configure-container-routing

http:
  middlewares:
    authelia-${app_id}:
      forwardAuth:
        address: "http://authelia:9091/sso/api/authz/forward-auth"
        trustForwardHeader: true
        authResponseHeaders:${headers}
EOF

    chmod 644 "${middleware_file}"
    log "Created middleware: ${middleware_file}"
}

# Generate path redirect config on websecure entrypoint
generate_path_redirect() {
    local app_id="$1"
    local external_port="$2"
    local redirect_file="${MIDDLEWARE_DIR}/redirect-${app_id}.yml"

    log "Generating path redirect /${app_id}/ → :${external_port}"

    cat > "${redirect_file}" << EOF
# Path redirect for ${app_id}: /${app_id}/ → :${external_port}/
# Auto-generated by configure-container-routing

http:
  routers:
    redirect-${app_id}-https:
      rule: "Host(\`${HALOS_DOMAIN}\`) && PathPrefix(\`/${app_id}/\`)"
      entrypoints:
        - websecure
      tls: {}
      middlewares:
        - redirect-${app_id}
      service: noop@internal
      priority: 100
    redirect-${app_id}-bare:
      rule: "Host(\`${HALOS_DOMAIN}\`) && Path(\`/${app_id}\`)"
      entrypoints:
        - websecure
      tls: {}
      middlewares:
        - add-slash-${app_id}
      service: noop@internal
      priority: 101
    redirect-${app_id}-http:
      rule: "Host(\`${HALOS_DOMAIN}\`) && PathPrefix(\`/${app_id}/\`)"
      entrypoints:
        - web
      middlewares:
        - redirect-to-https
      service: noop@internal
      priority: 100
    redirect-${app_id}-bare-http:
      rule: "Host(\`${HALOS_DOMAIN}\`) && Path(\`/${app_id}\`)"
      entrypoints:
        - web
      middlewares:
        - redirect-to-https
      service: noop@internal
      priority: 101
  middlewares:
    redirect-${app_id}:
      redirectRegex:
        regex: "^https://([^/]+)/${app_id}/(.*)"
        replacement: "https://\${1}:${external_port}/\${2}"
        permanent: false
    add-slash-${app_id}:
      redirectRegex:
        regex: "^https://([^/]+)/${app_id}$"
        replacement: "https://\${1}/${app_id}/"
        permanent: false
EOF

    chmod 644 "${redirect_file}"
    log "Created path redirect: ${redirect_file}"
}

# Write HALOS_EXTERNAL_PORT to the app's runtime env directory
write_external_port() {
    local app_id="$1"
    local package_name="$2"
    local external_port="$3"

    # Runtime env is at /run/container-apps/<package_name>/
    local runtime_dir="/run/container-apps/${package_name}"
    local port_file="${runtime_dir}/external-port.env"

    mkdir -p "${runtime_dir}"
    echo "HALOS_EXTERNAL_PORT=${external_port}" > "${port_file}"
    chmod 644 "${port_file}"
    log "Wrote HALOS_EXTERNAL_PORT=${external_port} to ${port_file}"
}

# Generate docker-compose override with Traefik labels
generate_override() {
    local routing_file="$1"
    local external_port="$2"

    # Parse routing.yml
    local app_id
    local service_name
    local port
    local backend_type
    local auth_mode

    app_id=$(yaml_get "app_id" < "$routing_file")
    service_name=$(yaml_get_deep "routing" "backend" "service" < "$routing_file")
    port=$(yaml_get_deep "routing" "backend" "port" < "$routing_file")
    backend_type=$(yaml_get_deep "routing" "backend" "type" < "$routing_file")
    backend_scheme=$(yaml_get_deep "routing" "backend" "scheme" < "$routing_file")
    auth_mode=$(yaml_get_nested "auth" "mode" < "$routing_file")

    # Validate required fields
    if [ -z "${app_id}" ]; then
        log "ERROR: Missing app_id in ${routing_file}"
        return 1
    fi

    if [ -z "${service_name}" ]; then
        log "ERROR: Missing routing.backend.service in ${routing_file}"
        return 1
    fi

    if [ -z "${port}" ]; then
        log "ERROR: Missing routing.backend.port in ${routing_file}"
        return 1
    fi

    # Default values
    [ -z "${backend_type}" ] && backend_type="container"
    [ -z "${auth_mode}" ] && auth_mode="forward_auth"

    local entrypoint="app-${external_port}"
    log "Processing ${app_id}: entrypoint=${entrypoint}, backend_port=${port}, auth=${auth_mode}"

    # Determine middleware
    local middleware_label=""
    if [ "${auth_mode}" = "forward_auth" ]; then
        if has_custom_headers "$routing_file"; then
            generate_middleware "${app_id}" "$routing_file"
            middleware_label="      traefik.http.routers.${app_id}-secure.middlewares: \"authelia-${app_id}@file\""
        else
            middleware_label="      traefik.http.routers.${app_id}-secure.middlewares: \"authelia@file\""
        fi
    fi

    # Determine backend configuration
    local scheme="${backend_scheme:-http}"
    local backend_label
    local scheme_label=""
    local transport_label=""
    if [ "${backend_type}" = "host" ]; then
        backend_label="      traefik.http.services.${app_id}.loadbalancer.server.url: \"${scheme}://host.docker.internal:${port}\""
    else
        backend_label="      traefik.http.services.${app_id}.loadbalancer.server.port: \"${port}\""
        if [ "${scheme}" = "https" ]; then
            scheme_label="      traefik.http.services.${app_id}.loadbalancer.server.scheme: \"https\""
            transport_label="      traefik.http.services.${app_id}.loadbalancer.serversTransport: \"insecure@file\""
        fi
    fi

    # Generate override file — router on dedicated entrypoint (no HTTP router needed)
    local override_file="${OUTPUT_DIR}/${app_id}.yml"

    cat > "${override_file}" << EOF
# Docker-compose override with Traefik labels for ${app_id}
# Auto-generated by configure-container-routing
# Source: ${routing_file}
# External port: ${external_port} (entrypoint: ${entrypoint})

services:
  ${service_name}:
    labels:
      traefik.enable: "true"
      # HTTPS router on dedicated entrypoint
      traefik.http.routers.${app_id}-secure.rule: "PathPrefix(\`/\`)"
      traefik.http.routers.${app_id}-secure.entrypoints: "${entrypoint}"
      traefik.http.routers.${app_id}-secure.tls: "true"
${middleware_label}
      # Backend service
${backend_label}
${scheme_label}
${transport_label}
EOF

    chmod 644 "${override_file}"
    log "Created override: ${override_file}"
}

# Main
main() {
    local app_id="$1"

    if [ -z "${app_id}" ]; then
        echo "Usage: configure-container-routing <app_id>" >&2
        exit 1
    fi

    local routing_file="${ROUTING_DIR}/${app_id}.yml"

    if [ ! -f "${routing_file}" ]; then
        log "No routing config for ${app_id} at ${routing_file}, skipping"
        exit 0
    fi

    # Ensure output directories exist
    mkdir -p "${OUTPUT_DIR}"
    mkdir -p "${MIDDLEWARE_DIR}"

    # Get package_name from routing file (for runtime env path)
    local package_name
    package_name=$(yaml_get "package_name" < "$routing_file")
    [ -z "${package_name}" ] && package_name="${app_id}"

    # Assign or retrieve persistent port
    local external_port
    external_port=$(get_or_assign_port "${app_id}")

    log "Configuring routing for ${app_id} (HALOS_DOMAIN=${HALOS_DOMAIN}, port=${external_port})"

    generate_override "${routing_file}" "${external_port}"
    generate_path_redirect "${app_id}" "${external_port}"
    write_external_port "${app_id}" "${package_name}" "${external_port}"
}

main "$@"
